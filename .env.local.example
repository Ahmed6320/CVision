# CVision Frontend Environment Variables
# Copy this to .env.local and fill in your values

# Anthropic Claude API
# Get your key from: https://console.anthropic.com/account/keys
VITE_ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxx

# Backend API
# Development
VITE_API_URL=http://localhost:5000

# Production
# VITE_API_URL=https://api.cvision.io

# Stripe Public Key
# Get your key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx

# Environment
VITE_ENVIRONMENT=development
