# CVision Backend Environment Variables
# Copy this to .env and fill in your values

# Node Environment
NODE_ENV=development
PORT=5000

# ============================================================================
# DATABASE - PostgreSQL / Supabase
# ============================================================================
# Get connection string from Supabase dashboard
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:password@localhost:5432/cvision

# ============================================================================
# STRIPE
# ============================================================================
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRICE_PRO=price_1QgXXXXXXXXXXXXX
STRIPE_PRICE_PREMIUM=price_1QgYYYYYYYYYYYYY
STRIPE_PRICE_LIFETIME=price_1QgZZZZZZZZZZZZZ

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# ============================================================================
# FRONTEND
# ============================================================================
FRONTEND_URL=http://localhost:5173

# Production
# FRONTEND_URL=https://cvision.io

# ============================================================================
# ANTHROPIC CLAUDE API
# ============================================================================
# Get key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# EMAILS (Optional - for transactional emails)
# ============================================================================
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@cvision.io

# ============================================================================
# ANALYTICS (Optional)
# ============================================================================
SENTRY_DSN=https://xxxxx@xxx.ingest.sentry.io/xxxxx
